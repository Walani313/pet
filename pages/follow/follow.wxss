/* 全局盒模型 */
view, text {
  box-sizing: border-box;
}

/* 容器背景（米色，和其他页面统一） */
.container {
  position: absolute;
  padding: 0;
  width: 100%;
  height: 100vh;
  background-color: rgb(254, 242, 230);
}

/* 蓝色半圆背景 */
.semicircle {
  position: absolute;
  top: -55%;
  left: 50%;
  width: 200%;
  height: 80%;
  background-color: rgb(69, 101, 169);
  border-radius: 50%;
  transform: translateX(-50%);
  z-index: 1;
}

/* 自定义导航栏（和其他页面完全一致） */
.custom-nav {
  position: relative;
  display: flex;
  align-items: center;
  margin-top: 120rpx;
  padding: 0 30rpx;
  color: white;
  z-index: 2;
}
.back-btn {
  display: flex;
  align-items: center;
}
.back-arrow {
  font-size: 32rpx;
  margin-right: 8rpx;
}
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: 500;
}

/* 内容容器 */
.content {
  position: relative;
  z-index: 2;
  padding: 0 30rpx;
  margin-top: 20rpx;
}

/* 空状态 */
.empty-view {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 关注列表（用户列表样式，更贴合关注场景） */
.follow-list {
  width: 100%;
}
.follow-item {
  display: flex;
  align-items: center;
  background-color: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
/* 用户头像 */
.follow-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
/* 用户信息 */
.follow-info {
  flex: 1;
}
.follow-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  display: block;
}
.follow-desc {
  font-size: 26rpx;
  color: #999;
}