.guide-swiper {
  width: 100vw;
  height: 100vh;
  background-color: #fef2e6;
}

.guide-item {
  position: relative;
  width: 100%;
  height: 100%;
  background-color: transparent;
}

.status-bar {
  height: 44px;
}

.splash-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1;
}

.splash-circle {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  filter: blur(2px);
}

.splash-circle.pink {
  top: -50rpx;
  right: -50rpx;
  background: rgba(255, 182, 193, 0.15);
  width: 300rpx;
  height: 300rpx;
}

.splash-circle.blue {
  top: -100rpx;
  left: -50rpx;
  background: rgba(91, 192, 222, 0.15);
  width: 250rpx;
  height: 250rpx;
}

.content {
  position: relative;
  z-index: 2;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title-container {
  text-align: center;
  margin-bottom: 40rpx;
  margin-top: 160rpx;
}

.title {
  font-size: 108rpx;
  font-weight: bold;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
  background: linear-gradient(45deg, #5BC0DE 30%, #FFB6C1 70%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  font-size: 36rpx;
  color: #5BC0DE;
  margin-top: 10rpx;
  letter-spacing: 2rpx;
  opacity: 0.8;
}

.pet-image {
  width: 100%;
  height: 800rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: -40rpx;
  position: relative;
}

.pet-image image {
  width: 100%;
  height: 100%;
  opacity: 0.95;
  object-fit: contain;
}

.cats-opacity {
  opacity: 0.9 !important;
}

.cats-light {
  opacity: 0.85 !important;
  filter: brightness(1.1) contrast(0.9) !important;
}

.guide-img {
  transition: all 0.3s ease;
  filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.1));
}

.description {
  font-size: 40rpx;
  color: #666;
  text-align: center;
  margin-top: -20rpx;
  line-height: 1.6;
  letter-spacing: 1rpx;
  padding: 0 30rpx;
  white-space: nowrap;
  background: linear-gradient(45deg, #5BC0DE 30%, #FFB6C1 70%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: bold;
}

.dots {
  position: absolute;
  bottom: 160rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(91, 192, 222, 0.3);
  transition: all 0.3s;
}

.dot.active {
  background: #5BC0DE;
  width: 32rpx;
  border-radius: 8rpx;
  box-shadow: 0 2px 4px rgba(91, 192, 222, 0.3);
}

.enter-btn {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #5BC0DE;
  color: white;
  padding: 20rpx 100rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  box-shadow: 0 4px 12px rgba(91, 192, 222, 0.3);
  transition: all 0.3s ease;
}

.enter-btn:active {
  transform: translateX(-50%) scale(0.98);
  box-shadow: 0 2px 8px rgba(91, 192, 222, 0.2);
} 