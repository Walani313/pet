<view class="container">
  <!-- 蓝色半圆背景（和work/like页一致） -->
  <view class="semicircle"></view>

  <!-- 自定义返回导航栏 -->
  <view class="custom-nav">
    <view class="back-btn" bindtap="goBack">
      <text class="back-arrow">←</text>
      <text class="back-text">返回</text>
    </view>
    <text class="nav-title">我的收藏</text>
  </view>

  <!-- 内容容器（避免被背景挡住） -->
  <view class="content">
    <!-- 空状态 -->
    <view class="empty-view" wx:if="{{bookmarkList.length === 0}}">
      <text class="empty-text">暂无收藏内容，快去收藏吧～</text>
    </view>
    
    <!-- 收藏列表（真实数据渲染） -->
    <view class="bookmark-list" wx:else>
      <view class="bookmark-item" wx:for="{{bookmarkList}}" wx:key="_id">
        <image class="bookmark-img" src="{{item.imgUrl || '/images/default.png'}}" mode="aspectFill"></image>
        <view class="bookmark-desc">
          <text class="bookmark-title">{{item.title}}</text>
          <text class="bookmark-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>
</view>