/* 搜索框样式 */
.search-box {
  position: absolute;
  bottom: 0px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  background-color: #ffffffe6;
  padding: 10px;
  border-radius: 25px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  width: 80%;
 
}

.search-input {
  flex: 1;
  padding: 5px 10px;
  border: none;
  background: transparent;
  font-size: 14px;
}

.search-button {
  background-color: #007AFF;
  color: white;
  border: none;
  border-radius: 20px;
  padding: 5px 15px;
  font-size: 14px;
  margin-left: 10px;
}

/* 搜索结果列表样式 */
.result-list {
  width: 100%;
  margin-top: 20px;
}

.result-item {
  padding: 10px;
  background-color: #f8f8f8;
  border-radius: 8px;
  margin-bottom: 10px;
  font-size: 14px;
  color: #333;
}
