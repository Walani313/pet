/* 设置容器占满整个屏幕 */
page{ background-color: #FEF2E6;}
.container {
  z-index: 9999;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
} 
.container1 {

  width: 100%;
  height: 100%;
}
/* 设置图片居中且填满容器 */
.fullscreen-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover; /* 使图片保持比例并填满容器 */
  pointer-events: none; 
}
.overlay-image {
  position: sticky; /* 或者使用其他布局方式，确保不干扰其他元素 */
  width: 750rpx; /* 与图片宽度一致 */
  height: 1500rpx; /* 与图片高度一致或稍大以容纳文本 */
  padding: 0 10rpx; /* 添加内边距以显示文本 */
  box-sizing: border-box; /* 包括内边距和边框在内计算宽度 */
  position: absolute;
  top: 40rpx;
  left: 0;
  pointer-events: none; /* 如果不希望覆盖图片影响点击事件，可以添加此行 */
}
.image-container {
  position: absolute;
  top: 20rpx;
  left: 0;
  position: relative;
  width: 100%;
  margin-bottom: 20px;

}

.image {
