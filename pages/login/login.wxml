<!-- pages/login/login.wxml -->
<view class="login-container">
  <view class="logo-section">
    <view class="title">
      <view>宠物</view>
      <view>管家通</view>
    </view>
    <view class="subtitle">CUTE PET STEWARD</view>
  </view>
  <view class="form-section">
    <view class="input-group">
      <input 
        type="text" 
        placeholder="请输入昵称" 
        bindinput="handleUsernameInput"
        value="{{username}}"
      />
    </view>
    <view class="input-group">
      <input 
        password
        placeholder="请输入密码" 
        bindinput="handlePasswordInput"
        value="{{password}}"
      />
    </view>
    <view class="remember-section">
      <checkbox value="remember" color="#5BC0DE"/>
      <text>记住密码</text>
      <text class="forget-pwd">忘记密码?</text>
    </view>
  </view>
  <view class="button-group">
    <button class="login-btn" bindtap="handleLogin">登录</button>
    <button class="register-btn" bindtap="handleRegister">注册</button>
  </view>
</view>