/* pages/know/know.wxss */
view,text{
  box-sizing: border-box;
}

.container {
  position: absolute;
  padding: 30rpx;
  width: 100%;
  height: 100vh;
  background-color: rgb(254,242,230);
}

.semicircle{
  position: absolute;
  top: -55%; 
  left: 50%; 
  width: 200%; 
  height: 80%; 
  background-color: rgb(69,101,169);
  border-radius: 50%; 
  transform: translateX(-50%); 
}

.search-box {
  position: relative;
  display: flex;
  margin-top: 120rpx;
  margin-bottom: 5rpx;
}

.search-box input {
  flex: 1;
  margin-right: 20rpx;
  padding: 18rpx;
  border: 1rpx solid #ccc;
  border-radius: 15px;
  background-color: white;
}

.search-box button {
  padding: 10rpx 30rpx;
  color: rgb(49, 68, 177);
  border: 1rpx solid rgb(58, 81, 209);
  border-radius: 15px;
  background: rgb(205, 217, 241);
}

.result-list {
  position: absolute;
  border-top: 1px solid lightgray;
  z-index: 1;
}

.result-item {
  position: relative;
  padding: 12px;
  background-color: white;
  border-bottom: 1px solid lightgray;
  width: 690rpx;
}

.result-item text {
  position: relative;
  font-size: 16px;
}

.books{
  position: relative;
  display: flex;
  justify-content: space-between;
}

.content{
  position: relative;
  font-family: 黑体;
  font-size: large;
  margin-top: 10rpx;
}

.book-button{
  background: linear-gradient(to bottom, rgb(246,194,235), rgb(171,194,238));
  color: white;
  font-family: 楷体;
  font-size: 30rpx;
  padding: 15rpx;
  border-radius: 10rpx;
}

.book1{
  position: relative;
  background-color: white;
  height: 510rpx;
  width: 400rpx;
  margin-top: 10rpx;
  border-radius: 20px;
  margin-right: 10rpx;
}

.book2{
  position: relative;
  background-color: white;
  height: 250rpx;
  width: 350rpx;
  margin-top: 10rpx;
  border-radius: 20px;
  margin-left: 10rpx;
}

.buttons{
  display: flex;
  justify-content: space-between;
}

.left-part{
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.right-part{
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.detail{
  display: flex;
}

.button1{
  background-color: rgb(239,179,176);
  color: white;
  font-family: 宋体;
  margin-top: 20rpx;
  padding: 16rpx;
  border-radius: 15rpx;
}

.button2{
  background-color: rgb(130,167,253);
  color: white;
  font-family: 宋体;
  margin-top: 20rpx;
  border-radius: 15rpx;
}
.more-books {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  margin: 20rpx 0;
  padding: 20rpx;
  background: #fff;
  border-radius: 20rpx;
}
.book-item {
  width: 280rpx;
  height: 380rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.hide-btn {
  width: 200rpx;
  margin-top: 20rpx;
}
/* 只加书籍简介样式 */
.intro {
  background:#fff;
  padding:25rpx;
  border-radius:15rpx;
  margin:20rpx 0;
  font-size:28rpx;
  line-height:1.6;
}
.hide-btn{
  margin-top:20rpx;
}