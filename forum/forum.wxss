/* pages/forum/forum.wxss */
page {
  background-color: #FEF2E6;
}

.container {
  min-height: 100vh;
  background-color: #FEF2E6;
  padding-bottom: 200rpx;
}

/* 背景图 */
.fullscreen-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 300rpx;
  object-fit: cover;
  pointer-events: none;
}

/* 搜索框区域 */
.image-container {
  position: relative;
  width: 100%;
  height: 200rpx;
  margin-top: 100rpx;
}

.image {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
}

.search-box {
  position: absolute;
  bottom: -30rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 10rpx 20rpx;
  border-radius: 50rpx;
  width: 80%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.search-input {
  flex: 1;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
  background: transparent;
}

.search-button {
  background-color: #5BC0DE;
  color: white;
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  margin-left: 20rpx;
}

/* 发布按钮 */
.circle-button {
  width: 100rpx !important;
  height: 100rpx !important;
  border-radius: 50%;
  background-color: #ff84a2;
  color: white;
  font-size: 60rpx;
  line-height: 100rpx;
  text-align: center;
  padding: 0;
  border: none;
  position: fixed;
  bottom: 200rpx;
  right: 40rpx;
  z-index: 100;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* 标签页 */
.tabs {
  display: flex;
  justify-content: space-around;
  background-color: #fff2c5;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #ddd;
  margin-top: 100rpx;
}

.tab {
  font-size: 32rpx;
  padding: 10rpx 40rpx;
  color: #666;
}

.tab.active {
  color: #ff84a2;
  border-bottom: 4rpx solid #ff84a2;
}

/* 帖子卡片 */
.content {
  padding: 20rpx;
}

.post-card {
  background-color: #fff2c5;
  border-radius: 20rpx;
  border: 2rpx solid #000;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

/* 用户信息区 */
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #ddd;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.post-time {
  font-size: 22rpx;
  color: #999;
}

.follow-btn {
  background-color: #5BC0DE;
  color: white;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 20rpx;
}

.post-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 图片区 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #eee;
}

/* 操作栏 */
.post-actions {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #ddd;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.action-icon {
  font-size: 36rpx;
}

/* 空状态 */
.loading-text, .empty-text {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

/* 搜索结果 */
.result-list {
  padding: 20rpx;
  background-color: white;
  margin: 20rpx;
  border-radius: 16rpx;
}

.result-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 28rpx;
}